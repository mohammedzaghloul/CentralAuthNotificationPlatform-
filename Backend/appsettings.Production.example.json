{
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:YOUR_SQL_HOST,1433;Database=CentralAuthNotificationPlatform;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=False;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "https://auth.your-domain.com",
    "Audience": "central-auth-api",
    "SigningKey": "replace-with-a-64-plus-character-random-secret",
    "ExpirationMinutes": 60,
    "OAuthAccessTokenMinutes": 10,
    "AuthorizationCodeMinutes": 5,
    "PasswordResetMinutes": 10
  },
  "Smtp": {
    "Host": "smtp.your-provider.com",
    "Port": 587,
    "EnableSsl": true,
    "UserName": "smtp-user",
    "Password": "smtp-password",
    "FromEmail": "no-reply@your-domain.com",
    "FromName": "Central Auth Hub"
  },
  "AllowedHosts": "auth.your-domain.com"
}
