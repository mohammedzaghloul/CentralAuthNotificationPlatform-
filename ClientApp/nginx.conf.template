server {
    listen ${PORT};
    server_name _;
    absolute_redirect off;
    port_in_redirect off;
    root /usr/share/nginx/html;
    index index.html;

    location = / {
        return 302 /dashboard/;
    }

    location /dashboard/ {
        try_files $uri $uri/ /index.html;
    }

    location = /runtime-config.js {
        add_header Cache-Control "no-store";
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
